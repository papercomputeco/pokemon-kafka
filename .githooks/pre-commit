#!/bin/bash
#
# Pre-commit hook: ruff linting + format check on staged Python files
#
# Install:  git config core.hooksPath .githooks
# Skip:     SKIP_LINT=1 git commit ...
# Bypass:   git commit --no-verify
#

set -e

echo "Running pre-commit checks..."

if ! command -v uv &> /dev/null; then
    echo "Error: uv is not installed."
    exit 1
fi

STAGED_PY_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)

if [ -z "$STAGED_PY_FILES" ]; then
    echo "No staged Python files to check."
    exit 0
fi

if [[ -z "${SKIP_LINT}" ]]; then
    echo "Running ruff check..."
    if ! uv run ruff check $STAGED_PY_FILES; then
        echo "Ruff check failed. Run 'uv run ruff check --fix' to auto-fix."
        exit 1
    fi

    echo "Running ruff format check..."
    if ! uv run ruff format --check $STAGED_PY_FILES; then
        echo "Format issues found. Run 'uv run ruff format' to fix."
        exit 1
    fi
else
    echo "Lint checks skipped (SKIP_LINT is set)"
fi

echo "Pre-commit checks passed."
